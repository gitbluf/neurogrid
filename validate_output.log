var builtinAgentDefinitions = [
  cortexDefinition,
  blueprintDefinition,
  blackiceDefinition,
  ghostDefinition,
  dataweaverDefinition,
  hardlineDefinition
];
var REPLACED_DEFAULT_AGENTS = [
  "general",
  "explore",
  "build",
  "plan"
];
function disableReplacedDefaults(existingAgents) {
  for (const name of REPLACED_DEFAULT_AGENTS) {
    const entry = existingAgents[name];
    if (typeof entry === "object" && entry !== null && typeof entry.prompt === "string" && entry.prompt.trim().length > 0) {
      continue;
    }
    existingAgents[name] = {
      ...typeof entry === "object" && entry !== null ? entry : {},
      disable: true
    };
  }
}
async function registerBuiltinAgents(config, directory) {
  const existingAgents = config.agent ?? {};
  const skills = await getAllSkills(directory);
  for (const def of builtinAgentDefinitions) {
    const agentConfig = def.create(config, existingAgents, skills);
    if (agentConfig) {
      existingAgents[def.name] = agentConfig;
    }
  }
  disableReplacedDefaults(existingAgents);
  config.agent = existingAgents;
  const currentDefault = config.default_agent;
  if (!currentDefault && existingAgents.cortex) {
    config.default_agent = "cortex";
  }
}

