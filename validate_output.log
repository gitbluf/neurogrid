// dist/hooks/command-apply.js
function createCommandApplyHook(directory) {
  return async (input, output) => {
    if (input.command !== "apply")
      return;
    const args = input.arguments?.trim();
    if (!args) {
      output.parts.push(createTextPart("Usage: `/apply <description of what to change>`\n\n" + `You must describe what you want changed. Examples:
` + "- `/apply fix the off-by-one error in src/utils/parse.ts`\n" + '- `/apply rename the variable "foo" to "count" in src/main.ts`\n' + "- `/apply add a null check before calling process() in handler.ts`"));
      return;
    }
    output.parts.push(createTextPart(`[APPLY-MODE] Working directory: ${directory}

` + `[APPLY-MODE] This is a direct-edit command, not a plan execution.

` + `## Constraints

` + `- Make ONLY the change described below. Nothing else.
` + `- Keep changes minimal and surgical.
` + `- Do NOT refactor, restructure, or reorganize surrounding code.
` + `- Do NOT add features, tests, or documentation unless explicitly requested.
` + `- Do NOT create or modify any plan files (.ai/plan-*.md).
` + `- Do NOT interact with the session-plan registry.
` + "- After making the change, provide a brief summary of exactly what was changed and which files were modified."));
  };
}

// dist/hooks/command-clean.js
import { access as access2, readdir as readdir2, unlink } from "node:fs/promises";
import { join as join2 } from "node:path";
function createCommandCleanHook(directory) {
  return async (input, output) => {
    if (input.command !== "clean")
      return;
    const aiDir = join2(directory, ".ai");
    const deleted = [];
    const errors = [];
    try {
      await access2(aiDir);
    } catch {
      output.parts.push(createTextPart("No `.ai/` directory found — nothing to clean."));
      return;
    }
    let entries;
    try {
      entries = await readdir2(aiDir);
    } catch (err) {
      output.parts.push(createTextPart(`Error reading .ai/ directory: ${err instanceof Error ? err.message : String(err)}`));
      return;
    }
    const mdFiles = entries.filter((f) => f.endsWith(".md"));
    const registryFile = ".session-plans.json";
    if (mdFiles.length === 0) {
      const registryPath2 = join2(aiDir, registryFile);
      try {
        await unlink(registryPath2);
        output.parts.push(createTextPart("No `.md` files found in `.ai/`. Removed session-plan registry."));
      } catch {
        output.parts.push(createTextPart("No `.md` files found in `.ai/` — nothing to clean."));
      }
      return;
    }
    for (const file of mdFiles) {
      const filePath = join2(aiDir, file);
      try {
        await unlink(filePath);
        deleted.push(file);
