          status: ts.status,
          error: ts.error,
          result: ts.result,
          worktreePath: ts.worktreePath ?? null,
          worktreeBranch: ts.worktreeBranch ?? null,
          durationMs: ts.startedAt && ts.completedAt ? ts.completedAt - ts.startedAt : undefined
        }));
        return JSON.stringify({
          swarmId: finalState.id,
          status: finalState.status,
          completedAt: finalState.completedAt,
          tasks: taskStates
