function createPlatformSwarmWaitTool() {
  return tool({
    description: "Wait for a swarm to complete. Blocks until all tasks reach a terminal state or the wait timeout is reached.",
    args: {
      swarmId: tool.schema.string().min(1).describe("The swarm ID to wait for"),
      timeout: tool.schema.number().min(1000).optional().describe("Max wait time in milliseconds (default: 600000 = 10 min)")
    },
    async execute(args, context) {
      const denied = enforceAgent(context, "ghost", "platform_swarm_wait");
      if (denied)
        return denied;
